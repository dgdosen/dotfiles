[submodule ".tmux/plugins/tpm"]
	path = .tmux/plugins/tpm
	url = https://github.com/tmux-plugins/tpm.git
[submodule ".zsh_customizations/plugins/zsh-syntax-highlighting"]
	path = .zsh_customizations/plugins/zsh-syntax-highlighting
	url = git@github.com:zsh-users/zsh-syntax-highlighting.git
[submodule ".zsh_customizations/themes/powerlevel10k"]
	path = .zsh_customizations/themes/powerlevel10k
	url = https://github.com/romkatv/powerlevel10k.git
